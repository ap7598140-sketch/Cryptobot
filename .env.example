# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alpaca Paper Trading (https://app.alpaca.markets → paper account)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Coinglass free tier API key (https://www.coinglass.com/pricing → free tier)
# Leave blank to skip liquidation level data
COINGLASS_API_KEY=

# CoinGecko API key (https://www.coingecko.com/en/api → free tier)
# Leave blank to use unauthenticated (rate-limited)
COINGECKO_API_KEY=
